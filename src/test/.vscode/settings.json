{
	"[typescript][json][jsonc][snippets]": {
		"files.insertFinalNewline": true
	},
	"chat.disableAIFeatures": true, // poisons diagnositics
	"editor.detectIndentation": false, // breaks `editor.update('tabSize', 3);` in VSCode Web
	"editor.insertSpaces": false,
	"editor.minimap.size": "fill",
	"editor.renderWhitespace": "boundary",
	"editor.tabSize": 4,
	"editor.wordBasedSuggestions": "off", // reduce noise in completions
	"files.autoSave": "off", // don't modify the fixtures files during tests
	"files.eol": "\r\n",
	"files.trimFinalNewlines": true,
	"json.schemaDownload.trustedDomains": {
		"https://raw.githubusercontent.com/RedCMD/TmLanguage-Syntax-Highlighter/main/vscode.tmLanguage.schema.json": true,
	},
	"workbench.colorTheme": "Dark Modern",
	"workbench.editor.wrapTabs": true,
	"workbench.secondarySideBar.defaultVisibility": "hidden",
}
